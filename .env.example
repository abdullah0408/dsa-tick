# PostgreSQL connection (replace with your credentials)
# You can get a free database URL from Neon: https://neon.com
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# App URL for client-side use
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Better Auth
BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app
# Secret key for Better Auth.
# Generate one using any of these commands:
#   bunx @better-auth/cli secret
#   npx @better-auth/cli secret
#   pnpm dlx @better-auth/cli secret
#   yarn dlx @better-auth/cli secret
BETTER_AUTH_SECRET=